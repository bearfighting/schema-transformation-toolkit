{
  "name": "type-schema-converter",
  "version": "0.1.0",
  "private": true,
  "description": "A schema and data model conversion toolkit for structured data formats and typed languages.",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "check:api": "node scripts/check-api-snapshots.mjs",
    "check:api:update": "node scripts/check-api-snapshots.mjs --update",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "check:public-api": "pnpm check:boundaries && pnpm check:api",
    "build": "pnpm -r --workspace-concurrency=1 --if-present build",
    "clean": "pnpm -r --if-present clean",
    "dev": "pnpm -r --if-present dev",
    "check": "pnpm format:check && pnpm lint && pnpm check:public-api && pnpm typecheck && pnpm test",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "verify": "pnpm check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/coverage-v8": "^4.1.10",
    "change-case": "^5.4.4",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "cac": "^7.0.0"
  }
}
