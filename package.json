{
  "name": "type-schema-converter",
  "version": "0.1.0",
  "private": true,
  "description": "A schema and data model conversion toolkit for structured data formats and typed languages.",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 --if-present build",
    "clean": "pnpm -r --if-present clean",
    "dev": "pnpm -r --if-present dev",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm lint && pnpm typecheck && pnpm test",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "change-case": "^5.4.4",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "tsup": "^8.5.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "cac": "^7.0.0"
  }
}
