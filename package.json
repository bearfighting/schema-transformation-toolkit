{
  "name": "all-in-one-data-type-converter",
  "version": "0.1.0",
  "private": true,
  "description": "A schema and data model conversion toolkit for structured data formats and typed languages.",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 --if-present build",
    "clean": "pnpm -r --if-present clean",
    "dev": "pnpm -r --if-present dev",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm lint && pnpm typecheck && pnpm test",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "change-case": "^5.4.4",
    "eslint": "^9.29.0",
    "prettier": "^3.6.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "zod": "^3.25.67"
  },
  "dependencies": {
    "cac": "^6.7.14"
  }
}
